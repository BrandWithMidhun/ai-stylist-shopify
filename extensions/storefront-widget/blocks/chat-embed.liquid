{%- comment -%}
  AI Stylist — App Embed (auto-injects chat bubble on every storefront page).

  Renders nothing when enable_widget is off, so disabling in theme editor
  fully removes the script tag and custom element from the page.

  CSP note: merchants with strict CSP must allowlist
    connect-src https://web-production-3b1d7.up.railway.app
  for the chat fetch. Surfaces in v2 if real merchants hit it.

  Config source: all chat config (agent name, primary color, welcome
  message, CTA label) lives in the app-data metafield app:ai_stylist /
  chat_config, written by /app/config save and read here via the Liquid
  `app` object. If the metafield is missing (very fresh install whose
  ensureMerchantConfig sync hasn't fired yet), the inline defaults below
  keep the widget functional with neutral copy.
{%- endcomment -%}

{%- if block.settings.enable_widget -%}
  {%- assign chat_config = app.metafields.ai_stylist.chat_config.value -%}
  <script>
    window.__AISTYLIST_CONFIG__ = {
      shopDomain: {{ shop.permanent_domain | json }},
      agentName: {{ chat_config.agentName | default: "AI Assistant" | json }},
      primaryColor: {{ chat_config.primaryColor | default: "#000000" | json }},
      welcomeMessage: {{ chat_config.welcomeMessage | default: "Hi! I'm your shopping assistant. How can I help you today?" | json }},
      ctaLabel: {{ chat_config.ctaLabel | default: "" | json }},
      configVersion: {{ chat_config.version | default: 0 | json }},
      chatEndpoint: "https://web-production-3b1d7.up.railway.app/api/chat/message"
    };
  </script>
  <script src="{{ 'chat-widget.js' | asset_url }}" defer></script>
  <aistylist-widget></aistylist-widget>
{%- endif -%}

{% schema %}
{
  "name": "AI Stylist Chat",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_widget",
      "label": "Show chat bubble on storefront",
      "default": true
    }
  ]
}
{% endschema %}

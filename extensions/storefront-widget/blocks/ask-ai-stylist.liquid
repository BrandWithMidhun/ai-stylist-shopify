{%- comment -%}
  AI Stylist — App Block (merchant-placeable CTA on product pages).

  Renders an "Ask AI Stylist" button that opens the chat widget with
  product context. The widget itself is provided by the storefront-widget
  App Embed; this block only supplies a click target and product payload.

  Variant fallback chain (matches v1 spec):
    1. Liquid renders product.selected_or_first_available_variant.id as data attr
    2. JS reads data attr as initial value
    3. On click, JS overrides with window.ShopifyAnalytics?.meta?.selectedVariantId
       if present (default themes), else keeps liquid value (custom themes)
{%- endcomment -%}

{%- liquid
  assign btn_label = block.settings.cta_label | default: 'Ask AI Stylist'
  assign style = block.settings.button_style | default: 'outline'
  assign show_icon = block.settings.show_icon
  assign variant_id = product.selected_or_first_available_variant.id
  assign featured_image = product.featured_image | image_url: width: 200
-%}

<div class="aistylist-cta-wrap" {{ block.shopify_attributes }}>
  <button
    type="button"
    class="aistylist-cta aistylist-cta--{{ style }}"
    data-aistylist-cta
    data-product-handle="{{ product.handle }}"
    data-product-title="{{ product.title | escape }}"
    data-product-image="{{ featured_image }}"
    data-variant-id="{{ variant_id }}"
    aria-label="{{ btn_label | escape }}"
  >
    {%- if show_icon -%}
      <svg class="aistylist-cta__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M21 12a8 8 0 0 1-11.5 7.2L3 21l1.8-6.5A8 8 0 1 1 21 12Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M12 7v3M12 13v.01" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    {%- endif -%}
    <span class="aistylist-cta__label">{{ btn_label | escape }}</span>
  </button>
</div>

<style>
  .aistylist-cta-wrap {
    /* Match the visual rhythm of typical Shopify cart-action stacks: full
       width, vertical breathing room above/below so the button sits between
       variant pickers and Add to Cart without crowding either. */
    margin: 12px 0;
    width: 100%;
  }
  .aistylist-cta {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    justify-content: center;
    /* Padding tuned to sit close to standard theme button height without
       outsizing Add to Cart. */
    padding: 13px 24px;
    /* Inherit theme button radius if available (Dawn et al. expose
       --buttons-radius / --button-border-radius). 4px fallback keeps the
       outline button visually subordinate to filled theme primaries. */
    border-radius: var(--buttons-radius, var(--button-border-radius, 4px));
    font: inherit;
    font-weight: 500;
    line-height: 1.2;
    cursor: pointer;
    transition: transform 150ms ease, background-color 200ms ease, color 200ms ease;
    /* Outline style — subordinate "discovery" CTA, defers to Add to Cart. */
    border: 1px solid {{ block.settings.primary_color | default: '#000000' }};
    background: transparent;
    color: {{ block.settings.primary_color | default: '#000000' }};
  }
  .aistylist-cta--filled {
    background: {{ block.settings.primary_color | default: '#000000' }};
    color: #ffffff;
  }
  .aistylist-cta:hover {
    background: {{ block.settings.primary_color | default: '#000000' }};
    color: #ffffff;
  }
  .aistylist-cta:focus-visible {
    outline: 2px solid {{ block.settings.primary_color | default: '#000000' }};
    outline-offset: 2px;
  }
  .aistylist-cta:active { transform: scale(0.98); }
  .aistylist-cta__icon { flex-shrink: 0; }
</style>

<script src="{{ 'cta-button.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Ask AI Stylist Button",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Ask AI Stylist"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "Show chat icon",
      "default": true
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "outline", "label": "Outline" },
        { "value": "filled", "label": "Filled" }
      ],
      "default": "outline"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary color",
      "default": "#000000"
    }
  ]
}
{% endschema %}

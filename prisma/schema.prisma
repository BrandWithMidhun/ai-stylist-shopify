// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

enum StoreMode {
  FASHION
  ELECTRONICS
  FURNITURE
  BEAUTY
  JEWELLERY
  GENERAL
}

enum CtaPlacement {
  PRODUCT_PAGE
  GLOBAL
  COLLECTION
}

model MerchantConfig {
  id                       String       @id @default(cuid())
  shop                     String       @unique
  storeMode                StoreMode    @default(GENERAL)
  chatWidgetEnabled        Boolean      @default(true)
  chatAgentName            String?
  shopDisplayName          String?
  chatPrimaryColor         String       @default("#000000")
  // 011a: optional 2-stop linear gradient. When chatPrimaryColorEnd is null,
  // the widget renders a solid color (current behavior).
  chatPrimaryColorEnd      String?
  chatPrimaryGradientAngle Int          @default(135)
  chatWelcomeMessage       String       @default("Hi! I'm your shopping assistant. How can I help you today?")
  ctaEnabled               Boolean      @default(true)
  ctaLabel                 String       @default("Need help choosing?")
  ctaPlacement             CtaPlacement @default(PRODUCT_PAGE)
  quizEnabled              Boolean      @default(true)
  lookbookEnabled          Boolean      @default(false)
  stylistAgentEnabled      Boolean      @default(false)
  commerceAgentEnabled     Boolean      @default(true)
  lastFullSyncAt           DateTime?
  // Phase 1: tracks when the rich knowledge record (metafields, metaobjects,
  // collections, descriptionText, knowledgeContentHash) was last fully
  // reconciled for this shop. Distinct from lastFullSyncAt so we can roll
  // out the new ingestion path without overloading the existing flag —
  // webhook handlers added in PR-C will gate on this one.
  lastKnowledgeSyncAt      DateTime?
  // PR-D: IANA timezone (e.g. "Asia/Kolkata") populated from Shopify
  // shop.ianaTimezone. Drives the in-worker cron tick that enqueues a
  // daily DELTA at 03:00 local. Default "UTC" for shops we haven't
  // refreshed yet. timezoneSyncedAt records the last refresh — cron
  // refreshes once per day per shop when stale.
  timezone                 String       @default("UTC")
  timezoneSyncedAt         DateTime?
  // PR-D: idempotency guard for the daily cron tick. The cron tick
  // computes the shop's local date, compares against this column, and
  // skips the enqueue if today's tick already fired. Stored as DATE
  // (no time component) so the comparison is exact.
  lastCronEnqueueDate      DateTime?    @db.Date
  // PR-2.1: tagging budget tripwires. Set when the per-day cumulative
  // Anthropic spend for the shop crosses 80% of the daily cap
  // (taggingBudgetWarnedAt) and 100% (taggingBudgetExceededAt). The
  // worker-tagging loop reads these to refuse new claims for the day;
  // the next day rollover resets to NULL via the cost-recording path.
  taggingBudgetWarnedAt    DateTime?
  taggingBudgetExceededAt  DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

// 011a: Quiz state machine.
//
// Anonymous-only in v1: keyed by (shopDomain, sessionId) where sessionId is
// the cookie UUID from the storefront widget. No customer account linking.
//
// v1 limitation: storeMode change after a quiz is COMPLETED orphans the
// existing row (different storeMode = different unique key). Acceptable —
// completed profile is no longer reachable, fresh quiz starts on next try.
// v2 could prompt the user to retake when storeMode changes.
enum QuizState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model QuizSession {
  id                 String       @id @default(cuid())
  shopDomain         String
  sessionId          String // anonymous cookie UUID from widget
  storeMode          StoreMode
  state              QuizState    @default(NOT_STARTED)
  startedAt          DateTime?
  completedAt        DateTime?
  currentQuestionKey String?
  answers            QuizAnswer[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([shopDomain, sessionId, storeMode])
  @@index([shopDomain, sessionId])
}

model QuizAnswer {
  id          String   @id @default(cuid())
  sessionId   String // FK to QuizSession.id (NOT the cookie UUID)
  questionKey String
  answerKey   String? // single-select
  answerKeys  String[] // multi-select
  answeredAt  DateTime @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionKey])
}

model Product {
  id                     String                       @id @default(cuid())
  shopDomain             String
  shopifyId              String
  handle                 String
  title                  String
  descriptionHtml        String?
  productType            String?
  vendor                 String?
  status                 String
  featuredImageUrl       String?
  imageUrls              String[]
  priceMin               Decimal?
  priceMax               Decimal?
  currency               String?
  shopifyTags            String[]
  totalInventory         Int?
  inventoryStatus        String
  shopifyCreatedAt       DateTime
  shopifyUpdatedAt       DateTime
  syncedAt               DateTime                     @default(now())
  deletedAt              DateTime?
  recommendationExcluded Boolean                      @default(false)
  taxonomyNodeId         String?
  embedding              Unsupported("vector(1024)")?
  embeddingUpdatedAt     DateTime?
  // Phase 1 knowledge-record fields. Additive — current chat path
  // (recommend_products / search_products) does not read any of these.
  // descriptionText: HTML-stripped plaintext, computed once at ingest so
  // embedders and tagging passes don't re-strip on every read.
  descriptionText        String?
  // knowledgeContentHash: sha256 hex over the canonical textual record
  // (title, descriptionText, productType, vendor, shopifyTags, collection
  // handles, textual metafields, metaobject refs). Phase 3 reads this to
  // skip re-embedding when content hasn't changed.
  knowledgeContentHash   String?
  knowledgeContentHashAt DateTime?
  // lastKnowledgeSyncAt: when the metafields/metaobjects/collections
  // surface for this product was last reconciled. Drift signal for the
  // catch-up cron in PR-D.
  lastKnowledgeSyncAt    DateTime?
  // embeddingContentHash: the hash the *current* embedding was built
  // from. NULL today; Phase 3 will populate on each (re-)embed and
  // compare against knowledgeContentHash to decide whether to skip.
  // Adding the column now avoids a Phase 3 migration that hits every row.
  embeddingContentHash   String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt

  variants     ProductVariant[]
  tags         ProductTag[]
  metafields   ProductMetafield[]
  collections  ProductCollection[]
  taxonomyNode TaxonomyNode?       @relation(fields: [taxonomyNodeId], references: [id], onDelete: SetNull)

  @@unique([shopDomain, shopifyId])
  @@index([shopDomain, status])
  @@index([shopDomain, inventoryStatus])
  @@index([shopDomain, productType])
  @@index([shopDomain, deletedAt])
  @@index([shopDomain, taxonomyNodeId])
  // Phase 3 Stage 2 hard-filter: budget queries hit priceMin per shop.
  @@index([shopDomain, priceMin])
}

// Phase 1: every metafield value across every namespace, keyed to a Product.
// `value` stays a string with `type` as discriminator (Shopify always
// serializes that way — single_line_text_field, number_decimal,
// metaobject_reference, list.metaobject_reference, etc.). Decode in code
// per-axis; no DB-level type discrimination.
model ProductMetafield {
  id                 String    @id @default(cuid())
  productId          String
  shopDomain         String
  namespace          String
  key                String
  type               String
  value              String    @db.Text
  // Populated when type ends in "_reference" or "list.*_reference". For
  // metaobject references, this is the metaobject GID — joined informally
  // to Metaobject.shopifyId. We don't FK across to Metaobject because
  // the referent may not be in our cache yet (race) or may be a non-
  // metaobject reference (Product, Collection, MediaImage).
  referenceGid       String?
  shopifyMetafieldId String
  shopifyUpdatedAt   DateTime?
  syncedAt           DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, namespace, key])
  @@index([shopDomain, namespace, key])
  @@index([productId])
  @@index([referenceGid])
}

// Phase 1: store-level cache of metaobject instances products reference.
// `fields` JSON shape: { fieldKey: { type, value, referenceGid? } } —
// flexible enough to absorb any merchant-defined metaobject definition
// without per-shop schema changes.
model Metaobject {
  id               String    @id @default(cuid())
  shopDomain       String
  shopifyId        String
  type             String
  handle           String?
  displayName      String?
  fields           Json
  shopifyUpdatedAt DateTime?
  syncedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([shopDomain, shopifyId])
  @@index([shopDomain, type])
}

// Phase 1: store-level cache of collections.
model Collection {
  id               String    @id @default(cuid())
  shopDomain       String
  shopifyId        String
  handle           String
  title            String
  descriptionHtml  String?   @db.Text
  descriptionText  String?   @db.Text
  sortOrder        String?
  // Smart collections recompute membership on Shopify's side without
  // firing per-product webhooks; flagging them lets the cron know to
  // reconcile their memberships even when nothing else looks dirty.
  isSmart          Boolean   @default(false)
  templateSuffix   String?
  shopifyUpdatedAt DateTime?
  syncedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products ProductCollection[]

  @@unique([shopDomain, shopifyId])
  @@index([shopDomain, handle])
}

// Phase 1: many-to-many product ↔ collection membership.
model ProductCollection {
  id           String   @id @default(cuid())
  productId    String
  collectionId String
  shopDomain   String
  addedAt      DateTime @default(now())

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([collectionId])
  @@index([shopDomain, collectionId])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  shopifyId         String
  title             String
  sku               String?
  price             Decimal
  compareAtPrice    Decimal?
  inventoryQuantity Int?
  inventoryItemId   String?
  availableForSale  Boolean
  option1           String?
  option2           String?
  option3           String?
  imageUrl          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, shopifyId])
  @@index([productId])
  @@index([inventoryItemId])
}

// PR-2.1: review state machine added alongside source.
//
// `source` is who *generated* the tag (AI / RULE / HUMAN).
// `status` is what the merchant has *decided* about it
// (PENDING_REVIEW / APPROVED / REJECTED).
//
// New AI tags land as (source=AI, status=PENDING_REVIEW). Rules write
// (source=RULE, status=APPROVED) — rules are merchant-deterministic,
// implicitly approved. HUMAN-marked tags land as (source=HUMAN,
// status=APPROVED). The migration backfills source='HUMAN' rows to
// status='APPROVED' as a one-time UPDATE.
//
// REJECTED rows persist (not deleted). The AI prompt receives the
// rejected (axis, value) pairs as exclusions so re-tag does not
// re-suggest values the merchant already vetoed.
enum TagReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model ProductTag {
  id         String          @id @default(cuid())
  productId  String
  shopDomain String
  axis       String
  value      String
  confidence Float?
  source     String
  locked     Boolean         @default(false)
  metadata   Json?
  status     TagReviewStatus @default(PENDING_REVIEW)
  reviewedAt DateTime?
  reviewedBy String? // Shopify staff member GID (gid://shopify/StaffMember/<id>)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, axis, value])
  @@index([shopDomain, axis, value])
  @@index([productId])
  @@index([shopDomain, source])
  @@index([shopDomain, status])
}

model ProductTagAudit {
  id            String   @id @default(cuid())
  productId     String
  shopDomain    String
  axis          String
  action        String
  previousValue String?
  newValue      String?
  source        String
  actorId       String?
  createdAt     DateTime @default(now())

  @@index([productId, createdAt])
  @@index([shopDomain, createdAt])
}

// Hierarchical category tree per shop. Roots have parentId=null. Each node
// owns axisOverrides JSON ([{ axis, type, values?, order? }]) that augments
// or overrides the storeMode-level axis vocabulary; getEffectiveAxes walks
// node → root, merging children-win-on-conflict. matchKeywords drives the
// naive keyword-scoring matcher (006a §4.3) that assigns each Product a
// taxonomyNodeId at sync time.
model TaxonomyNode {
  id            String   @id @default(cuid())
  shopDomain    String
  parentId      String?
  name          String
  slug          String
  position      Int      @default(0)
  axisOverrides Json
  matchKeywords String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent   TaxonomyNode?  @relation("TaxonomyTree", fields: [parentId], references: [id], onDelete: Cascade)
  children TaxonomyNode[] @relation("TaxonomyTree")
  products Product[]

  @@unique([shopDomain, slug])
  @@index([shopDomain, parentId])
}

// Phase 1 (PR-A): DB-backed sync job model. Replaces the in-memory
// `kind: "sync"` slot in app/lib/catalog/jobs.server.ts. The other in-memory
// kinds (batch_tag, apply_rules, rematch_taxonomy) stay in jobs.server.ts —
// Phase 2 territory, untouched here.
//
// Three job kinds share one row shape:
//   INITIAL       — first-ever ingestion for a shop (no lastFullSyncAt)
//   MANUAL_RESYNC — merchant-triggered full re-ingestion. On enqueue, we
//                   cancel any QUEUED/RUNNING DELTA for the same shop.
//   DELTA         — daily catch-up cron (PR-D)
//
// The phase enum is a coarse-grained progress marker for the future Phase 8
// dashboard. It deliberately does NOT include a WAITING_BULK_OP value —
// PR-A scope leaves that seam for when we onboard a >10K-product merchant
// and need the Bulk Operations API path. Adding an enum value later is a
// non-breaking migration.
enum CatalogSyncJobKind {
  INITIAL
  MANUAL_RESYNC
  DELTA
}

enum CatalogSyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum CatalogSyncJobPhase {
  COLLECTIONS
  METAOBJECTS
  PRODUCTS
  FINALIZE
}

model CatalogSyncJob {
  id                   String               @id @default(cuid())
  shopDomain           String
  kind                 CatalogSyncJobKind
  status               CatalogSyncJobStatus @default(QUEUED)
  phase                CatalogSyncJobPhase?
  // Counts. `total*` populate when the corresponding phase begins. The
  // worker (PR-B) writes these on every batch boundary.
  totalProducts        Int?
  processedProducts    Int                  @default(0)
  failedProducts       Int                  @default(0)
  totalCollections     Int?
  processedCollections Int                  @default(0)
  totalMetaobjects     Int?
  processedMetaobjects Int                  @default(0)
  // Resume state. Each cursor commits in the same transaction as the
  // upserts for the batch it points past, so the worst-case work loss
  // from a crash is one batch.
  productsCursor       String?
  metaobjectsCursor    String?
  collectionsCursor    String?
  // PR-C cursor age probe: wall-clock time the corresponding *Cursor was
  // last persisted (or null if never written). Worker logs
  //   cursorAgeMs = Date.now() - <phase>CursorAt
  // at fetch time so we can characterize the Shopify Admin API cursor TTL
  // anomaly seen during PR-B's graceful-shutdown tests (cursors went stale
  // during ~70s container restarts in 2/5 runs). Schema-backed (not in-
  // memory) so the cross-restart case — exactly the case we observed —
  // is captured. Migration: 20260429173559_add_cursor_at.
  productsCursorAt     DateTime?
  metaobjectsCursorAt  DateTime?
  collectionsCursorAt  DateTime?
  // Lifecycle.
  enqueuedAt           DateTime             @default(now())
  startedAt            DateTime?
  finishedAt           DateTime?
  // heartbeatAt is touched on every batch + on every saveCursor /
  // updateProgress / heartbeat call. Stuck-job recovery (PR-A
  // sync-jobs lib) compares heartbeatAt against
  // KNOWLEDGE_WORKER_HEARTBEAT_TIMEOUT_MS (default 5min) and resets
  // RUNNING → QUEUED so the next claim resumes from cursor — the
  // work is idempotent so resuming is safe and far better UX than
  // marking FAILED.
  heartbeatAt          DateTime?
  // Error surface.
  errorMessage         String?              @db.Text
  errorCount           Int                  @default(0)
  // Free-form summary written at finishJob. Phase 8 dashboard reads
  // this for the "recent runs" panel. Shape is per-kind:
  //   INITIAL/MANUAL_RESYNC: { batchCount, durationMs, ... }
  //   DELTA: { driftCount, ... }
  summary              Json?
  // PR-D: source that triggered the row. Null for legacy rows; "CRON"
  // for cron-tick-driven DELTAs; "WEBHOOK" / "MANUAL" reserved for
  // future use by enqueueDeltaForShop callers + manual resync UI.
  // Lets the dashboard filter cron-driven runs separately when
  // monitoring webhook reliability via DELTA drift.
  triggerSource        String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  failures CatalogSyncJobFailure[]
  // NOTE: a partial unique index on (shopDomain) WHERE status='RUNNING'
  // enforces "at most one running job per shop". Prisma can't express a
  // partial unique index in the schema DSL, so the migration adds it via
  // raw SQL — see prisma/migrations/<ts>_add_catalog_sync_job/migration.sql.

  @@index([shopDomain, status])
  @@index([shopDomain, kind, status])
  @@index([heartbeatAt])
}

model CatalogSyncJobFailure {
  id         String   @id @default(cuid())
  jobId      String
  shopDomain String
  // PRODUCT | COLLECTION | METAOBJECT | BATCH — kept as a free string
  // rather than an enum so the worker can log new failure kinds (e.g.
  // METAFIELD_PAGE) without a migration.
  kind       String
  shopifyGid String?
  message    String   @db.Text
  attempt    Int      @default(1)
  occurredAt DateTime @default(now())

  job CatalogSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([shopDomain, occurredAt])
}

// Deterministic if-this-then-that tag rules. conditions JSON matches the
// Condition union in app/lib/catalog/rule-engine.server.ts (single condition
// or any/all/not nesting). effects JSON is [{ axis, value }] with value as
// string (single) or string[] (multi). Rules write source=RULE,
// confidence=1.0, locked=false. Locking remains HUMAN-only.
model TaggingRule {
  id             String   @id @default(cuid())
  shopDomain     String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  priority       Int      @default(100)
  taxonomyNodeId String?
  conditions     Json
  effects        Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shopDomain, enabled, priority])
}

// PR-D: Customer profile is the first-class entity for the customer side
// of the recommendation engine (brief §5). Identity + computed attributes
// live here; mode-specific structured attributes live in
// CustomerProfileAttribute (key/value with mode tag) so adding a new
// store mode does not require a migration. Behavioral events stream into
// CustomerEvent. CustomerSession bridges anonymous-cookie sessions to
// identified profiles (Phase 5 wires the merge primitive).
//
// originatedFromAgent: true when the profile was created by the chat
// agent before the Shopify customer existed (anonymous → identification
// via lookbook download or substantive quiz completion). A future
// customers/create webhook reconciles by email when the merchant invites
// the customer or they create an account.
//
// deletedAt + nulled PII columns implement the GDPR redact contract
// (customers/redact, customers/delete) — see softDeleteCustomerProfile
// in app/lib/customers/redact.server.ts.
model CustomerProfile {
  id                       String    @id @default(cuid())
  shopDomain               String
  shopifyCustomerId        String?
  email                    String?
  phone                    String?
  firstName                String?
  lastName                 String?
  locale                   String?
  // Demographic. Free-string today; constrain when the quiz wires in.
  gender                   String?
  ageBand                  String?
  region                   String?
  // Behavioral aggregates. Recompute path is best-effort: customers/*
  // and orders/* webhooks update these incrementally; PR-D backfill
  // seeds initial values. Drift is acceptable; analytics queries can
  // recompute from CustomerEvent if exact counts matter.
  conversationCount        Int       @default(0)
  lastSessionAt            DateTime?
  ordersCount              Int       @default(0)
  totalSpendCents          Int       @default(0)
  // Phase 3+ predictions. NULL today; populated when the learning system
  // lands. Adding the columns now avoids a Phase 3 migration that hits
  // every row.
  predictedStyleCluster    String?
  aovBand                  String?
  repurchasePredisposition Float?
  // Provenance.
  originatedFromAgent      Boolean   @default(false)
  shopifyCreatedAt         DateTime?
  shopifyUpdatedAt         DateTime?
  syncedAt                 DateTime  @default(now())
  // GDPR redact / customers/delete sets deletedAt and nulls the PII
  // columns above. Behavioral aggregates and shopifyCustomerId stay so
  // analytics queries don't break.
  deletedAt                DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  attributes CustomerProfileAttribute[]
  sessions   CustomerSession[]
  events     CustomerEvent[]

  // shopifyCustomerId is nullable for anonymous-originated profiles per
  // brief §5 (e.g. lookbook download or substantive quiz before any
  // Shopify customer exists). Postgres treats NULL as distinct in unique
  // indexes, so multiple anonymous rows per shop are allowed. They merge
  // into an identified profile when the customer authenticates and
  // Phase 5's merge primitive runs.
  @@unique([shopDomain, shopifyCustomerId])
  @@index([shopDomain, email])
  @@index([shopDomain, phone])
  @@index([shopDomain, deletedAt])
}

// Mode-tagged key/value. Adding a new store mode is a constants change
// in code, not a schema migration — the (storeMode, key) pair carries
// the schema. Examples per brief §5:
//   FASHION:    bodyType=hourglass, fitPreference=oversized, occasion=daily
//   FURNITURE:  roomType=living_room, dimensions=10x12, materialPreference=wood
//   ELECTRONICS: useCase=gaming, budgetBand=premium
// source values: QUIZ | CHAT | PURCHASE | AGENT | RULE.
model CustomerProfileAttribute {
  id         String    @id @default(cuid())
  profileId  String
  shopDomain String
  storeMode  StoreMode
  key        String
  value      String    @db.Text
  source     String
  confidence Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  profile CustomerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, storeMode, key])
  @@index([shopDomain, storeMode, key, value])
}

// Anonymous + identified sessions — bridge for the merge primitive that
// Phase 5 will exercise. PR-D creates the table; storefront wiring
// arrives in Phase 5.
//
// cookieSessionId is the storefront widget's anonymous cookie UUID; it
// is the lookup column for cookie-based queries (uniquely indexed).
// CustomerEvent.sessionId references this row's PK (id), not the cookie
// — so a session merge that updates profileId here automatically
// reflects on every CustomerEvent emitted before identification.
model CustomerSession {
  id              String    @id @default(cuid())
  shopDomain      String
  cookieSessionId String
  profileId       String?
  startedAt       DateTime  @default(now())
  lastActiveAt    DateTime  @default(now())
  identifiedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile CustomerProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  events  CustomerEvent[]

  @@unique([shopDomain, cookieSessionId])
  @@index([profileId])
}

// Append-only behavioral stream. Drives the learning system + analytics
// (brief §5, §7). 90-day retention applies only to ConversationMessage
// (Phase 5); CustomerEvent is a "derived signal" per scope-decisions §3
// and survives indefinitely.
//
// kinds remain behavioral-only — profile attribute changes (e.g.
// customers/update with new email) are NOT events; they update the
// CustomerProfile row directly.
enum CustomerEventKind {
  PRODUCT_VIEWED
  PRODUCT_CLICKED
  ADD_TO_CART
  CHECKOUT_STARTED
  ORDER_PLACED
  LOOKBOOK_DOWNLOADED
  QUIZ_COMPLETED
  CHAT_STARTED
  CHAT_ENDED
  RECOMMENDATION_SHOWN
  RECOMMENDATION_CLICKED
}

model CustomerEvent {
  id         String            @id @default(cuid())
  shopDomain String
  profileId  String?
  // FK to CustomerSession.id (the cuid PK, not the cookie UUID).
  // onDelete: SetNull preserves analytics rows if a session is ever
  // deleted; profileId behaves the same for the same reason.
  sessionId  String?
  kind       CustomerEventKind
  // Free-form context. Per kind:
  //   PRODUCT_VIEWED:     { productGid, source }
  //   ORDER_PLACED:       { orderGid, totalCents, items: [{ productGid, qty, ... }] }
  //   LOOKBOOK_DOWNLOADED: { lookbookId }
  //   ...
  // GDPR redact scrubs PII keys via softDeleteCustomerProfile; behavioral
  // keys (productGid, kind, totalCents, items, etc.) are preserved.
  context    Json
  occurredAt DateTime          @default(now())
  createdAt  DateTime          @default(now())

  profile CustomerProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  session CustomerSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([shopDomain, profileId, occurredAt])
  @@index([shopDomain, sessionId, occurredAt])
  @@index([shopDomain, kind, occurredAt])
}

// PR-2.1: DB-backed queue for AI tagging runs. Parallel to
// CatalogSyncJob but distinct because (a) tagging is the first feature
// that costs real money per call (so cost observability is first-class
// on the row) and (b) tagging failure must not block catalog sync.
//
// Three kinds:
//   SINGLE_PRODUCT   — fired by webhooks (PRODUCTS_CREATE) or by the
//                      worker DELTA path when knowledgeContentHash
//                      changes. Routed to the SINGLE_PRODUCT/MANUAL
//                      daily cap.
//   INITIAL_BACKFILL — first-pass tagging across the full catalog
//                      (PR-2.2 territory). Routed to the BACKFILL
//                      cap (separate, larger).
//   MANUAL_RETAG     — merchant-triggered single-product retag from
//                      the embed app. Routed to the daily cap.
//
// triggerSource is a free string mirroring CatalogSyncJob's pattern:
// WEBHOOK_CREATE | DELTA_HASH_CHANGE | MANUAL | INITIAL_BACKFILL | CRON.
//
// Cost is in microdollars (1 USD = 1_000_000 micros) stored as BigInt
// to avoid float drift; checkBudgetForKind sums per-day across rows
// for the daily cap; per-job costUsdMicros is the per-run rollup.
//
// Partial unique indexes (NOT expressible in Prisma DSL — added in raw
// SQL by the migration):
//   - (shopDomain, productId) WHERE status='QUEUED' AND productId IS
//     NOT NULL — enforces QUEUED-only dedup for SINGLE_PRODUCT/
//     MANUAL_RETAG rows at the DB layer.
//   - (shopDomain) WHERE kind='INITIAL_BACKFILL' AND status IN
//     ('QUEUED','RUNNING') — at most one backfill per shop in flight.
enum TaggingJobKind {
  SINGLE_PRODUCT
  INITIAL_BACKFILL
  MANUAL_RETAG
}

enum TaggingJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  BUDGET_PAUSED
}

model TaggingJob {
  id                String           @id @default(cuid())
  shopDomain        String
  // NULL for INITIAL_BACKFILL (job spans all products); set for
  // SINGLE_PRODUCT and MANUAL_RETAG.
  productId         String?
  kind              TaggingJobKind
  status            TaggingJobStatus @default(QUEUED)
  triggerSource     String
  // Lifecycle.
  enqueuedAt        DateTime         @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?
  heartbeatAt       DateTime?
  // Counts. totalProducts populates for INITIAL_BACKFILL only;
  // SINGLE_PRODUCT/MANUAL_RETAG leave it null and write
  // processedProducts in {0,1}.
  totalProducts     Int?
  processedProducts Int              @default(0)
  failedProducts    Int              @default(0)
  skippedProducts   Int              @default(0)
  // Cost ledger. costUsdMicros is the per-job total Anthropic spend
  // in microdollars; inputTokens/outputTokens are the underlying token
  // counts so we can recompute against future model price changes.
  costUsdMicros     BigInt           @default(0)
  inputTokens       Int              @default(0)
  outputTokens      Int              @default(0)
  // Error surface. errorClass is one of RATE_LIMIT | AUTH |
  // MALFORMED_JSON | CONNECTION | OTHER (free string per the
  // CatalogSyncJobFailure precedent).
  errorClass        String?
  errorMessage      String?          @db.Text
  errorCount        Int              @default(0)
  // Free-form summary written at finishJob.
  summary           Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([shopDomain, status])
  @@index([shopDomain, kind, status])
  @@index([heartbeatAt])
  @@index([shopDomain, productId])
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

enum StoreMode {
  FASHION
  ELECTRONICS
  FURNITURE
  BEAUTY
  JEWELLERY
  GENERAL
}

enum CtaPlacement {
  PRODUCT_PAGE
  GLOBAL
  COLLECTION
}

model MerchantConfig {
  id                       String       @id @default(cuid())
  shop                     String       @unique
  storeMode                StoreMode    @default(GENERAL)
  chatWidgetEnabled        Boolean      @default(true)
  chatAgentName            String?
  shopDisplayName          String?
  chatPrimaryColor         String       @default("#000000")
  // 011a: optional 2-stop linear gradient. When chatPrimaryColorEnd is null,
  // the widget renders a solid color (current behavior).
  chatPrimaryColorEnd      String?
  chatPrimaryGradientAngle Int          @default(135)
  chatWelcomeMessage       String       @default("Hi! I'm your shopping assistant. How can I help you today?")
  ctaEnabled               Boolean      @default(true)
  ctaLabel                 String       @default("Need help choosing?")
  ctaPlacement             CtaPlacement @default(PRODUCT_PAGE)
  quizEnabled              Boolean      @default(true)
  lookbookEnabled          Boolean      @default(false)
  stylistAgentEnabled      Boolean      @default(false)
  commerceAgentEnabled     Boolean      @default(true)
  lastFullSyncAt           DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

// 011a: Quiz state machine.
//
// Anonymous-only in v1: keyed by (shopDomain, sessionId) where sessionId is
// the cookie UUID from the storefront widget. No customer account linking.
//
// v1 limitation: storeMode change after a quiz is COMPLETED orphans the
// existing row (different storeMode = different unique key). Acceptable —
// completed profile is no longer reachable, fresh quiz starts on next try.
// v2 could prompt the user to retake when storeMode changes.
enum QuizState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model QuizSession {
  id                 String       @id @default(cuid())
  shopDomain         String
  sessionId          String // anonymous cookie UUID from widget
  storeMode          StoreMode
  state              QuizState    @default(NOT_STARTED)
  startedAt          DateTime?
  completedAt        DateTime?
  currentQuestionKey String?
  answers            QuizAnswer[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([shopDomain, sessionId, storeMode])
  @@index([shopDomain, sessionId])
}

model QuizAnswer {
  id          String   @id @default(cuid())
  sessionId   String // FK to QuizSession.id (NOT the cookie UUID)
  questionKey String
  answerKey   String? // single-select
  answerKeys  String[] // multi-select
  answeredAt  DateTime @default(now())

  session QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionKey])
}

model Product {
  id                     String    @id @default(cuid())
  shopDomain             String
  shopifyId              String
  handle                 String
  title                  String
  descriptionHtml        String?
  productType            String?
  vendor                 String?
  status                 String
  featuredImageUrl       String?
  imageUrls              String[]
  priceMin               Decimal?
  priceMax               Decimal?
  currency               String?
  shopifyTags            String[]
  totalInventory         Int?
  inventoryStatus        String
  shopifyCreatedAt       DateTime
  shopifyUpdatedAt       DateTime
  syncedAt               DateTime  @default(now())
  deletedAt              DateTime?
  recommendationExcluded Boolean   @default(false)
  taxonomyNodeId         String?
  embedding              Unsupported("vector(1024)")?
  embeddingUpdatedAt     DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  variants     ProductVariant[]
  tags         ProductTag[]
  taxonomyNode TaxonomyNode?    @relation(fields: [taxonomyNodeId], references: [id], onDelete: SetNull)

  @@unique([shopDomain, shopifyId])
  @@index([shopDomain, status])
  @@index([shopDomain, inventoryStatus])
  @@index([shopDomain, productType])
  @@index([shopDomain, deletedAt])
  @@index([shopDomain, taxonomyNodeId])
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  shopifyId         String
  title             String
  sku               String?
  price             Decimal
  compareAtPrice    Decimal?
  inventoryQuantity Int?
  inventoryItemId   String?
  availableForSale  Boolean
  option1           String?
  option2           String?
  option3           String?
  imageUrl          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, shopifyId])
  @@index([productId])
  @@index([inventoryItemId])
}

model ProductTag {
  id         String   @id @default(cuid())
  productId  String
  shopDomain String
  axis       String
  value      String
  confidence Float?
  source     String
  locked     Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, axis, value])
  @@index([shopDomain, axis, value])
  @@index([productId])
  @@index([shopDomain, source])
}

model ProductTagAudit {
  id            String   @id @default(cuid())
  productId     String
  shopDomain    String
  axis          String
  action        String
  previousValue String?
  newValue      String?
  source        String
  actorId       String?
  createdAt     DateTime @default(now())

  @@index([productId, createdAt])
  @@index([shopDomain, createdAt])
}

// Hierarchical category tree per shop. Roots have parentId=null. Each node
// owns axisOverrides JSON ([{ axis, type, values?, order? }]) that augments
// or overrides the storeMode-level axis vocabulary; getEffectiveAxes walks
// node → root, merging children-win-on-conflict. matchKeywords drives the
// naive keyword-scoring matcher (006a §4.3) that assigns each Product a
// taxonomyNodeId at sync time.
model TaxonomyNode {
  id            String   @id @default(cuid())
  shopDomain    String
  parentId      String?
  name          String
  slug          String
  position      Int      @default(0)
  axisOverrides Json
  matchKeywords String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  parent   TaxonomyNode?  @relation("TaxonomyTree", fields: [parentId], references: [id], onDelete: Cascade)
  children TaxonomyNode[] @relation("TaxonomyTree")
  products Product[]

  @@unique([shopDomain, slug])
  @@index([shopDomain, parentId])
}

// Deterministic if-this-then-that tag rules. conditions JSON matches the
// Condition union in app/lib/catalog/rule-engine.server.ts (single condition
// or any/all/not nesting). effects JSON is [{ axis, value }] with value as
// string (single) or string[] (multi). Rules write source=RULE,
// confidence=1.0, locked=false. Locking remains HUMAN-only.
model TaggingRule {
  id             String   @id @default(cuid())
  shopDomain     String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  priority       Int      @default(100)
  taxonomyNodeId String?
  conditions     Json
  effects        Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shopDomain, enabled, priority])
}

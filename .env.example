SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=
SHOPIFY_APP_URL=
DATABASE_URL=
ANTHROPIC_API_KEY=
# Voyage AI embeddings — used by the recommendation layer
VOYAGE_API_KEY=
# Catalog sync worker (PR-B): how long a RUNNING CatalogSyncJob can go
# without a heartbeat before sweepStuckJobs resets it to QUEUED. Default
# 300000 (5 minutes) when unset. Set lower (e.g. 90000) once Phase 8
# monitoring is in place. Same value applies to web + worker services.
KNOWLEDGE_WORKER_HEARTBEAT_TIMEOUT_MS=
# Tagging engine (PR-2.1): per-product cost cap in microdollars.
# 1 USD = 1,000,000 micros. Default 5000 = $0.005 per product. Enforced
# post-call: if a product's cumulative cost exceeds this, the next
# tagging call for the same product is refused.
TAGGING_COST_PER_PRODUCT_USD_MICROS=
# Tagging engine (PR-2.1): per-shop per-day daily cap for SINGLE_PRODUCT
# and MANUAL_RETAG kinds, in microdollars. Default 500000 = $0.50/day.
# When the day's cumulative spend crosses 80% the worker logs
# tagging_budget_warning and writes MerchantConfig.taggingBudgetWarnedAt;
# at 100% the worker marks in-flight rows BUDGET_PAUSED and refuses new
# claims for the shop until the next day rolls over.
TAGGING_COST_PER_SHOP_DAY_USD_MICROS=
# Tagging engine (PR-2.1): separate budget for INITIAL_BACKFILL kind, in
# microdollars. Default 10000000 = $10. Backfill of the dev shop's 1,169
# products at the per-product cap is ~$5.85, so $10 covers a full pass
# with margin. Tracked per active backfill job, not per day.
TAGGING_BACKFILL_BUDGET_USD_MICROS=
